# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# 운영 계정 user.id — 생성권 무제한(크레딧 차감 면제). 미설정 시 무제한 계정 없음.
# Kakao/Google OAuth provider 키는 앱이 아니라 Supabase Auth config(Management API)에 저장.
OPS_USER_ID=

# fal.ai (server-only)
FAL_KEY=
# fal.ai ADMIN scope key — 잔액 조회용 (hard cap: $2 미만이면 생성 중단).
# 미설정 시 잔액 체크 없이 동작. fal dashboard 에서 ADMIN scope 로 발급.
FAL_ADMIN_KEY=

# Public site URL (used for OG images, share links, PayApp feedback/return URLs)
# ⚠️ Vercel prod 에 반드시 실제 도메인 설정 (미설정 시 결제 콜백이 localhost 로 빌드돼 깨짐)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# PayApp (무사업자 결제) — 판매자 관리 > 설정 > 연동정보. 미설정 시 결제 비활성(503).
# PAYAPP_USERID: 판매자 아이디 / PAYAPP_LINKVAL: 연동VALUE(웹훅 위변조 차단, 필수)
# PAYAPP_LINKKEY: 연동KEY(취소 API용, v1 선택). 절대 NEXT_PUBLIC_ 로 노출 금지.
PAYAPP_USERID=
PAYAPP_LINKVAL=
PAYAPP_LINKKEY=

# cron 보호 시크릿 — cron-job.org 가 x-cron-secret 헤더로 전달. 미설정 시 해당 cron 비활성(503).
# 보호 대상(전부 동일 시크릿): POST /api/ops/reconcile(결제 대사) · /api/ops/telemetry-maintain(텔레메트리)
#   · /api/ops/content-maintain(만료 하이라이트 purge·고아 얼굴 sweep·takedown 물리삭제 백스톱).
# 충분히 긴 랜덤 문자열.
CRON_SECRET=

# Sentry (에러/경고 알림). 미설정 시 Sentry 전부 no-op (앱 정상).
# DSN 만 있으면 런타임 캡처 동작. AUTH_TOKEN/ORG/PROJECT 는 빌드 시 소스맵 업로드용(선택).
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
# (선택) 클라 이벤트 environment 구분 — Vercel 에 NEXT_PUBLIC_VERCEL_ENV=production 등 추가 시 사용.
# NEXT_PUBLIC_VERCEL_ENV=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# fal.ai (server-only)
FAL_KEY=
# fal.ai ADMIN scope key — 잔액 조회용 (hard cap: $2 미만이면 생성 중단).
# 미설정 시 잔액 체크 없이 동작. fal dashboard 에서 ADMIN scope 로 발급.
FAL_ADMIN_KEY=

# Public site URL (used for OG images and share links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
